.duck-editor-root {

    padding: 10px;
}

.duck-image {
    width: auto;

}


#question-input{
    width: 100%;
}
#unity-text-input{
    width: 100%;

}

.ask-duck-button{
    background-color: yellow;
    color: black;
}

.ask-duck-button:hover{
    background-color: orange;
    cursor: link;
}

#animate-duck-button{
    position: absolute;
    height: 50px;
    width: 50px;
    cursor: link;
}

.box-field {
        width: 50%;
    height: 200px;
    min-height: 100px;
    max-height: 400px;
    align-self: flex-end;
    margin-left: auto;
    margin-right: 0;
    padding: 10px;   
    border-color: orange;
    background-color: yellow;
    white-space: pre-wrap;
    overflow: scroll;
}

#chat-text{
    color: black;
    font-size: 18px;
    overflow: scroll;
}

.chat-scroll-view{
    height: 50%;
    background-color: grey;
    
}

.title-label{
    font-size: 52px;
    font-weight: bold;
    color: purple;
    align-self: center;
}

/* Toggle row for small control buttons */
.toggle-container {
    height: 50px;
    flex-direction: row;
    flex-wrap: nowrap;
    gap: 8px;
    align-items: center;
    justify-content: flex-start;
    margin-bottom: 2px;
    
}

/* Individual toggle buttons inside the row */
.toggle-button {
    width: 33%;

    padding-top: 6px;
    padding-bottom: 6px;
    background-color: khaki;
    color: black;
    border-radius: 4px;
    align-self: center;
}

/* Hover/active states */
.toggle-button:hover {
    background-color: orange;
    cursor: pointer;
}

.toggle-button:active {
    background-color: darkorange;
}

.toggle-button.selected {
    background-color: orange;
    color: white;
}