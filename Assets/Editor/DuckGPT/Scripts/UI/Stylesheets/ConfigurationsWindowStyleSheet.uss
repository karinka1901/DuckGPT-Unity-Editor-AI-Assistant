.config-root{
    -unity-font-definition: url("project://database/Assets/Editor/DuckGPT/Font/WindowsXPFont.otf");
    font-size: 15px;
    padding-left: 10px;
    padding-right: 10px;
    background-color: rgb(128, 128, 128);
    color: black;

}



.tab-container {
   flex-direction: row;
    justify-content: center;
    align-items: center;
    width: 100%;
}


#SettingsTabButton,
#CacheTabButton {
    width: 50%;
    background-color: rgb(9, 26, 110);
    color: white;

}

#SectionLabel {
    font-size: 16px;
    font-weight: bold;
    align-self: center;
    padding-top: 15px;
    padding-bottom: 8px;
    color: yellow;
}


.buttons-container {
    flex-direction: row;
    justify-content: center;
    align-items: center;
    align-self: center;
    width: 97.5%;
    padding-bottom: 20px;
}

.settings-button  {

    width: 50%; 
    margin-top: 4px;
}

.duck-name-container {
    flex-direction: row;
    justify-content: flex-start;
    align-items: center;
    width: 100%;
}

.duck-name-label {
    width: 20%;
}

.duck-name-field {
    width: 80%;
}


.custom-button {

    background-color: rgb(153, 153,153);
    color: black;
    -unity-font: url("project://database/Assets/Editor/DuckGPT/Font/W95FA.otf");
    font-size: 15px;

    border-top-left-radius: 0px;
    border-top-right-radius: 0px;
    border-bottom-left-radius: 0px;
    border-bottom-right-radius: 0px;

    border-bottom-width: 1.77px;
    border-left-width: 1.77px;
    border-right-width: 1.77px;
    border-top-width: 1.77px;

    border-bottom-color: rgb(36, 36, 36);
    border-left-color: rgb(190, 190, 190);
    border-right-color: black;
    border-top-color: rgb(204, 204, 204);

    cursor: link;
}


.custom-button:hover {
    background-color: rgb(166, 166, 166);
}

.custom-button:active {
   background-color: rgb(104, 104, 104);
    border-bottom-color: rgb(223, 223, 223);
    border-left-color: rgb(64, 64, 64);
    border-right-color: rgb(223, 223, 223);
    border-top-color: rgb(64, 64, 64);
}

#unity-text-input{
    background-color: rgb(81,81,81);

}

.unity-text-element{
    padding-left: 5px;
}

/* Items in the dropdown list */
.unity-popup-field__dropdown .unity-text-element {
    -unity-font: url("project://database/Assets/Editor/DuckGPT/Font/WindowsXPFont.otf");
    font-size: 15px;
    color: black;
}