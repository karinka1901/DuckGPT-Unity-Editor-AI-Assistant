.duck-editor-root {
    background-color: #d5c6e4;
    padding: 10px;
}

.duck-image {
    width: auto;

}


#question-input{
    width: 100%;
}
#unity-text-input{
    width: 100%;

}

.ask-duck-button{
    background-color: yellow;
    color: black;
}

.ask-duck-button:hover{
    background-color: orange;
    cursor: link;
}

#animate-duck-button{
    position: absolute;
    height: 50px;
    width: 50px;
    cursor: link;
}

.box-field {
        width: 50%;
    height: 200px;
    min-height: 100px;
    max-height: 400px;
    align-self: flex-end;
    margin-left: auto;
    margin-right: 0;
    padding: 10px;   
    border-color: orange;
    background-color: yellow;
    white-space: pre-wrap;
    overflow: scroll;
}

#chat-text{
    color: black;
    font-size: 18px;
    overflow: scroll;
}

.chat-scroll-view{
    height: 50%;
    background-color: grey;
    
}

.title-label{
    font-size: 52px;
    font-weight: bold;
    color: purple;
    align-self: center;
}